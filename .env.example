DATABASE_URL="mysql://root:root@localhost:3306/alhathlul_db"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
OTP_EXPIRES_MINUTES=5
# Temporary: force every customer OTP to a fixed value so testers can sign in
# without SMS. Leave blank/unset in production.
DEV_OTP_OVERRIDE=123456

# Bunny CDN convention for brand logos. The backend returns
# ${BUNNY_BRAND_BASE_URL}/{slug}.${BUNNY_BRAND_IMAGE_EXT} for every brand.
# The frontend falls back to DEFAULT_BRAND_IMAGE_URL via <img onError>.
BUNNY_BRAND_BASE_URL=https://your-zone.b-cdn.net/brand
BUNNY_BRAND_IMAGE_EXT=png
DEFAULT_BRAND_IMAGE_URL=https://your-zone.b-cdn.net/brand/default/default.png
